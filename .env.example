# =====================================================================
# YOUFEED — variabili d'ambiente
# Copia in .env e popola con i valori reali. NON committare .env.
# =====================================================================

# --- Generale ---
YF_ENV=development                          # development | staging | production
YF_DEBUG=true
YF_SECRET_KEY=change-me-32-bytes-minimum    # itsdangerous + sessioni
YF_PUBLIC_BASE_URL=http://localhost:8000    # in prod: https://www.youfeed.it
# In prod: https://www.youfeed.it
YF_FRONTEND_BASE_URL=http://localhost:5173

# --- Postgres ---
# DATABASE_URL: driver async (asyncpg), usato dall'app
# DATABASE_URL_SYNC: driver sync (psycopg2), usato da Alembic per le migration
DATABASE_URL=postgresql+asyncpg://youfeed:youfeed@localhost:5432/youfeed
DATABASE_URL_SYNC=postgresql://youfeed:youfeed@localhost:5432/youfeed

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
RQ_REDIS_URL=redis://localhost:6379/1

# --- Manticore ---
MANTICORE_HOST=127.0.0.1
MANTICORE_PORT=9306                         # SQL endpoint (MySQL protocol)
MANTICORE_HTTP_PORT=9308                    # HTTP/JSON endpoint

# --- Email (OVH SMTP) ---
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=587                               # STARTTLS
SMTP_USER=noreply@youfeed.it
SMTP_PASSWORD=                              # password della casella
SMTP_FROM_ADDRESS=noreply@youfeed.it
SMTP_FROM_NAME=YouFeed
SMTP_USE_TLS=true                           # STARTTLS
SMTP_USE_SSL=false                          # in alternativa: porta 465 + USE_SSL=true

# --- Cookie / sessione ---
SESSION_COOKIE_NAME=yf_session
SESSION_COOKIE_DOMAIN=                      # vuoto in dev; .youfeed.it in prod
SESSION_COOKIE_SECURE=false                 # true in prod (HTTPS)
SESSION_COOKIE_SAMESITE=lax
SESSION_LIFETIME_DAYS=30

# --- Rate limit ---
RATE_LIMIT_ANON_PER_MIN=60
RATE_LIMIT_USER_PER_MIN=600

# --- MaxMind ---
MAXMIND_DB_DIR=/var/lib/youfeed/maxmind     # in dev: ./data/maxmind
MAXMIND_LICENSE_KEY=                        # da account MaxMind per refresh

# --- Storage immagini ---
IMAGES_DIR=/var/lib/youfeed/images          # in dev: ./data/images
IMAGES_PUBLIC_PREFIX=/images                # path pubblico servito da Apache
IMAGE_MOBILE_WIDTH=370
IMAGE_DESKTOP_MAX_WIDTH=1200
IMAGE_WEBP_QUALITY=80

# --- Google OAuth (v1.1, lascia vuoto per ora) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# --- Web Push VAPID (v1.2, lascia vuoto per ora) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@youfeed.it

# --- Anthropic (v1.2 LLM fallback, lascia vuoto per ora) ---
ANTHROPIC_API_KEY=

# --- Logging ---
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                              # true in prod
